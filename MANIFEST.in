include *.txt
include README.rst
include pyproject.toml

recursive-include offlinefolium *.py
recursive-include offlinefolium *.js
recursive-include offlinefolium/plugins *
recursive-include offlinefolium/templates *

prune examples
prune tests
prune docs
prune *.egg-info

exclude *.yml
exclude .pre-commit-config.yaml
exclude *.enc
exclude .gitignore
exclude .isort.cfg
